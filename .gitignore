# OS
.DS_Store

# Editors
.vscode/
.idea/
*.swp

# Node / Bun
node_modules/
*.log

# Environment
.env
.env.local
.env.*

# Gas City machine-local workspace identity
.gc/site.toml

# Gas City installs Claude Code skills as absolute-path symlinks during `gc init`.
# These regenerate on a fresh `gc init` and would dangle on any clone, so we untrack them.
city/.claude/skills/

# The rig is its own git repo (required by bd auto-export and gc doctor).
# Parent should not try to track its contents; managed independently inside.
rss-reader/

# SQLite runtime artifacts
*.db-journal
*.db-shm
*.db-wal
